{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Current File",
      "type": "debugpy",
      "request": "launch",
      "python": "D:/LOCAL_CODE/environments/mps-expenses/Scripts/python.exe",
      "program": "${file}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: Audit Pipeline",
      "type": "debugpy",
      "request": "launch",
      "python": "D:/LOCAL_CODE/environments/mps-expenses/Scripts/python.exe",
      "program": "${workspaceFolder}/run.py",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Python: Dashboard App",
      "type": "debugpy",
      "request": "launch",
      "python": "D:/LOCAL_CODE/environments/mps-expenses/Scripts/python.exe",
      "program": "${workspaceFolder}/dashboard/app.py",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    }
  ]
}